# App
APP_NAME=KonaMall
DEBUG=true
BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/konamall

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (JSON 배열 또는 쉼표 구분: http://localhost:3000,http://127.0.0.1:3000)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Exchange Rate & Pricing
DEFAULT_EXCHANGE_RATE=1350.0
DEFAULT_MARGIN_PERCENT=30.0
FREE_SHIPPING_THRESHOLD_KRW=50000
DEFAULT_SHIPPING_COST_KRW=3000

# ── Translation (번역 파이프라인) ──────────────────────────────────────────
# DeepL API: https://www.deepl.com/pro-api (무료 50만자/월)
DEEPL_API_KEY=your-deepl-api-key-here
# OpenAI API: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
# 번역 Redis 캐시 TTL (초, 기본 24h)
TRANSLATION_CACHE_TTL=86400

# ── KakaoPay ────────────────────────────────────────────────────────────────
# https://developers.kakaopay.com/
KAKAO_PAY_ADMIN_KEY=your-kakao-pay-admin-key
KAKAO_PAY_CID=TC0ONETIME

# ── NaverPay ────────────────────────────────────────────────────────────────
# https://developer.pay.naver.com/
NAVER_PAY_CLIENT_ID=your-naver-pay-client-id
NAVER_PAY_CLIENT_SECRET=your-naver-pay-client-secret
NAVER_PAY_CHAIN_ID=your-naver-pay-chain-id

# ── Cloudflare R2 (이미지 CDN) ─────────────────────────────────────────────
# https://dash.cloudflare.com/ → R2 → API Tokens
R2_ACCOUNT_ID=your-cf-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=konamall-images
R2_PUBLIC_URL=https://images.konamall.com

